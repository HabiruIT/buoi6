		{
			"name": "Products",
			"item": [
				{
					"name": "Get All Products (Public)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/products",
							"host": ["{{baseUrl}}"],
							"path": ["products"]
						}
					}
				},
				{
					"name": "Get All Products (with filters)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/products?title=test&minPrice=0&maxPrice=1000&page=1&limit=5",
							"host": ["{{baseUrl}}"],
							"path": ["products"],
							"query": [
								{ "key": "title", "value": "test" },
								{ "key": "minPrice", "value": "0" },
								{ "key": "maxPrice", "value": "1000" },
								{ "key": "page", "value": "1" },
								{ "key": "limit", "value": "5" }
							]
						}
					}
				},
				{
					"name": "Get Product By ID (Public)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/products/PRODUCT_ID_HERE",
							"host": ["{{baseUrl}}"],
							"path": ["products", "PRODUCT_ID_HERE"]
						}
					}
				},
				{
					"name": "Create Product (ADMIN/MOD)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"San pham test\",\n  \"price\": 100000,\n  \"description\": \"Mo ta san pham\",\n  \"category\": \"CATEGORY_ID_HERE\",\n  \"images\": [\"https://example.com/image.png\"]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/products",
							"host": ["{{baseUrl}}"],
							"path": ["products"]
						}
					}
				},
				{
					"name": "Update Product (ADMIN/MOD)",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"San pham updated\",\n  \"price\": 200000\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/products/PRODUCT_ID_HERE",
							"host": ["{{baseUrl}}"],
							"path": ["products", "PRODUCT_ID_HERE"]
						}
					}
